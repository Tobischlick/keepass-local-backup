# Path to your OneDrive/Cloud database
SOURCE_DB=/home/username/OneDrive/Database.kdbx
# Path where local backups should be stored
BACKUP_DIR=/home/username/Documents/KeePassBackups
# How many days to keep backups
RETENTION_DAYS=30
# How many seconds to wait on startup for the cloud drive to mount
# (Only used if the script is run without the --now flag)
SLEEP_DELAY=30